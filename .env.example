# --- Zerf configuration --------------------------------------------------
# 1. Copy to .env:           cp .env.example .env && chmod 600 .env
# 2. Generate secrets:       see README.md "Quick start" for copy-paste commands
# 3. Set deployment-specific variables below (local vs. public)

# -- REQUIRED TO SET (all deployments) ------------------------------------------------

# Random secret for session-cookie signing (generate with: openssl rand -hex 32).
ZERF_SESSION_SECRET=
ZERF_POSTGRES_PASSWORD=
# Choose any name for database name and user
ZERF_POSTGRES_DB=
ZERF_POSTGRES_USER=

# -- Required for public deployment with Caddy (start_public.sh) ---------------
#
# Your public hostname — e.g. "zerf.example.com". This is used for generating the TLS certificate and for CORS configuration.
# ZERF_PUBLIC_URL and ZERF_ALLOWED_ORIGINS are derived from this value automatically.
# Not needed for local deployment (start_local.sh uses http://localhost:3333 internally).
#
ZERF_DOMAIN=

# -- Optional -----------------------------------------------------------------

# Backups are executed automatically. Default: every 24h, keep for 30 days. It must be a positive integer.
# BACKUP_INTERVAL_SECONDS=86400
# BACKUP_RETENTION_DAYS=30

# Set automatically by the start scripts from the current Git checkout.
# Override only when deploying from a source archive without Git metadata.
# ZERF_GIT_COMMIT=unknown
