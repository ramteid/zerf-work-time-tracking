# --- KitaZeit configuration --------------------------------------------------
# Copy this file to `.env` and adjust the values. NEVER commit `.env` to git.
# After editing, ensure the file is not world-readable:  chmod 600 .env

# Public hostname (Caddy will obtain a Let's Encrypt cert for this name).
KITAZEIT_DOMAIN=example.com

# Mandatory: e-mail used for the bootstrap admin account.
KITAZEIT_ADMIN_EMAIL=admin@example.com

# Mandatory: long random secret used to derive session-cookie security.
# Generate with:    openssl rand -hex 32
KITAZEIT_SESSION_SECRET=replace-with-output-of-openssl-rand-hex-32

# Mandatory for the bundled PostgreSQL service. Use a URL-safe random value;
# `openssl rand -hex 32` keeps the derived app connection URL valid.
KITAZEIT_POSTGRES_DB=kitazeit
KITAZEIT_POSTGRES_USER=kitazeit
KITAZEIT_POSTGRES_PASSWORD=replace-with-output-of-openssl-rand-hex-32

# Optional: override the database connection entirely, e.g. for managed
# PostgreSQL. For remote databases, prefer sslmode=require or verify-full.
# KITAZEIT_DATABASE_URL=postgres://kitazeit:...@db.example.com:5432/kitazeit?sslmode=require

# Hardening flags — keep these on for any internet-facing deployment.
KITAZEIT_SECURE_COOKIES=true
KITAZEIT_ENFORCE_CSRF=true
KITAZEIT_ENFORCE_ORIGIN=true

# --- SMTP (optional) ---------------------------------------------------------
# Outbound email for in-app notifications (week reopen requests, approvals).
# Leave KITAZEIT_SMTP_HOST or KITAZEIT_SMTP_FROM unset to disable email
# entirely; in-app notifications still work.
# KITAZEIT_SMTP_HOST=smtp.example.com
# KITAZEIT_SMTP_PORT=587
# KITAZEIT_SMTP_USERNAME=
# KITAZEIT_SMTP_PASSWORD=
# KITAZEIT_SMTP_FROM="KitaZeit <noreply@example.com>"
# KITAZEIT_SMTP_ENCRYPTION=starttls   # starttls | tls | none
