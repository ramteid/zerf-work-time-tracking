{
  "name": "kitazeit-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --check \"src/**/*.{js,svelte,css,json}\" \"index.html\"",
    "format:write": "prettier --write \"src/**/*.{js,svelte,css,json}\" \"index.html\"",
    "test": "vitest run"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sveltejs/vite-plugin-svelte": "^3.1.2",
    "eslint": "^9.14.0",
    "globals": "^15.12.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.3.3",
    "prettier-plugin-svelte": "^3.2.7",
    "svelte": "^4.2.19",
    "vite": "^5.4.10",
    "vitest": "^2.1.5"
  },
  "dependencies": {
    "flatpickr": "^4.6.13"
  }
}
