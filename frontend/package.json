    "jsdom": "^24.1.3",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.55.5",
    "vite": "^5.4.21",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "flatpickr": "^4.6.13",
    "jspdf": "^4.2.1"
  }
